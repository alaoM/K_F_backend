<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Your Password — FKstores</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f8;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f8;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;max-width:600px;width:100%;">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#243e6b 0%,#1a2b4a 100%);padding:36px 40px;text-align:center;">
              <h1 style="margin:0;font-size:30px;font-weight:900;color:#f6c947;">FKstores</h1>
              <p style="margin:4px 0 0;font-size:11px;font-weight:700;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:4px;">fkstores.com</p>
            </td>
          </tr>
          <tr><td style="height:4px;background:#f6c947;"></td></tr>

          <!-- Body -->
          <tr>
            <td style="padding:40px;">
              <h2 style="margin:0 0 6px;font-size:22px;font-weight:900;color:#243e6b;">Reset Your Password 🔑</h2>
              <p style="margin:0 0 24px;font-size:15px;color:#374151;line-height:1.7;">
                We received a request to reset the password for your FKstores account. Click the button below to create a new password. This link will expire in <strong>15 minutes</strong>.
              </p>

              <!-- CTA -->
              <div style="text-align:center;margin:32px 0;">
                <a href="{{url}}"
                   style="background-color:#243e6b;color:#ffffff;padding:16px 48px;text-decoration:none;border-radius:10px;font-size:15px;font-weight:900;display:inline-block;letter-spacing:1px;text-transform:uppercase;">
                  Reset Password
                </a>
              </div>

              <div style="background-color:#fff7ed;border-left:4px solid #f6c947;border-radius:6px;padding:16px;margin:24px 0;">
                <p style="margin:0;font-size:13px;color:#92400e;line-height:1.6;">
                  ⚠️ If you did not request a password reset, please ignore this email. Your password will remain unchanged. For security concerns, contact <a href="mailto:support@fkstores.com" style="color:#243e6b;">support@fkstores.com</a>.
                </p>
              </div>

              <!-- Fallback link -->
              <div style="margin-top:20px;padding-top:20px;border-top:1px solid #f3f4f6;">
                <p style="font-size:12px;color:#9ca3af;margin:0 0 6px;">Can't click the button? Copy and paste this link into your browser:</p>
                <p style="font-size:12px;word-break:break-all;margin:0;">
                  <a href="{{url}}" style="color:#243e6b;">{{url}}</a>
                </p>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f9fafb;padding:24px 40px;text-align:center;border-top:1px solid #e5e7eb;">
              <p style="margin:0 0 4px;font-size:12px;color:#9ca3af;">
                © {{year}} FKstores — Golden Shopping Experience.
              </p>
              <p style="margin:0;font-size:12px;">
                <a href="https://fkstores.com" style="color:#243e6b;text-decoration:none;">fkstores.com</a>
                &nbsp;·&nbsp;
                <a href="mailto:support@fkstores.com" style="color:#243e6b;text-decoration:none;">Support</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>