<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 24px; background-color: #ffffff; border-radius: 16px; border: 1px solid #e5e7eb; color: #111827;">

  <!-- Header -->
  <div style="text-align: center; margin-bottom: 32px;">
    <h1 style="color: #10b981; font-size: 28px; margin-bottom: 8px;">
      Welcome to AgroCommerce 🌱
    </h1>
    <p style="color: #6b7280; font-size: 16px; margin: 0;">
      Your trusted digital marketplace for agriculture
    </p>
  </div>

  <!-- Body -->
  <div style="background-color: #f9fafb; padding: 24px; border-radius: 12px;">
    <p style="font-size: 16px; margin-top: 0;">
      Hello <strong>{{name}}</strong>,
    </p>

    <p style="font-size: 15px; color: #374151;">
      Thank you for creating an account on AgroCommerce. To keep your account secure and get started, please verify your email address.
    </p>

    <!-- CTA -->
    <div style="text-align: center; margin: 32px 0;">
      <a href="{{verificationUrl}}"
        style="background-color: #10b981; color: #ffffff; padding: 14px 36px; text-decoration: none; border-radius: 10px; font-size: 16px; font-weight: 600; display: inline-block;">
        Verify Email Address
      </a>
    </div>

    <p style="font-size: 13px; color: #6b7280;">
      This verification link will expire in <strong>24 hours</strong>.  
      If you did not sign up for AgroCommerce, you can safely ignore this email.
    </p>
  </div>

  <!-- Fallback link -->
  <div style="margin-top: 24px; padding-top: 16px; border-top: 1px solid #e5e7eb;">
    <p style="font-size: 12px; color: #9ca3af;">
      Trouble clicking the button? Copy and paste this link into your browser:
    </p>
    <p style="font-size: 12px; word-break: break-all;">
      <a href="{{verificationUrl}}" style="color: #10b981;">
        {{verificationUrl}}
      </a>
    </p>
  </div>

  <!-- Footer -->
  <div style="text-align: center; margin-top: 32px; font-size: 12px; color: #9ca3af;">
    <p style="margin: 0;">
      © {{year}} AgroCommerce. All rights reserved.
    </p>
  </div>
</div>
