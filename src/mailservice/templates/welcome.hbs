<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome to FKstores</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f8;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f8;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;max-width:600px;width:100%;">

          <!-- Header Banner -->
          <tr>
            <td style="background:linear-gradient(135deg,#243e6b 0%,#1a2b4a 100%);padding:40px 40px 32px;text-align:center;">
              <h1 style="margin:0;font-size:32px;font-weight:900;color:#f6c947;letter-spacing:-0.5px;">FKstores</h1>
              <p style="margin:6px 0 0;font-size:11px;font-weight:700;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:4px;">fkstores.com</p>
            </td>
          </tr>

          <!-- Gold accent bar -->
          <tr>
            <td style="height:4px;background:#f6c947;"></td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:40px;">
              <h2 style="margin:0 0 8px;font-size:26px;font-weight:900;color:#243e6b;">Welcome to FKstores! 🎉</h2>
              <p style="margin:0 0 24px;font-size:13px;color:#f6c947;font-weight:700;text-transform:uppercase;letter-spacing:3px;">Nigeria's Premium Fashion Marketplace</p>

              <p style="font-size:16px;color:#374151;line-height:1.7;margin:0 0 16px;">
                Hello <strong style="color:#243e6b;">{{name}}</strong>,
              </p>

              <p style="font-size:15px;color:#374151;line-height:1.7;margin:0 0 24px;">
                Thank you for joining <strong>FKstores</strong> — where fashion meets excellence. To complete your registration and unlock access to thousands of premium fashion brands, please verify your email address.
              </p>

              <!-- CTA Button -->
              <div style="text-align:center;margin:36px 0;">
                <a href="{{verificationUrl}}"
                   style="background-color:#f6c947;color:#243e6b;padding:16px 48px;text-decoration:none;border-radius:10px;font-size:15px;font-weight:900;display:inline-block;letter-spacing:1px;text-transform:uppercase;">
                  Verify My Email
                </a>
              </div>

              <p style="font-size:13px;color:#6b7280;line-height:1.6;margin:0 0 8px;">
                This link expires in <strong>24 hours</strong>. If you did not create an account on FKstores, you can safely ignore this email.
              </p>

              <!-- Fallback link -->
              <div style="margin-top:24px;padding-top:20px;border-top:1px solid #f3f4f6;">
                <p style="font-size:12px;color:#9ca3af;margin:0 0 6px;">Trouble clicking the button? Copy and paste this link:</p>
                <p style="font-size:12px;word-break:break-all;margin:0;">
                  <a href="{{verificationUrl}}" style="color:#243e6b;">{{verificationUrl}}</a>
                </p>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f9fafb;padding:28px 40px;text-align:center;border-top:1px solid #e5e7eb;">
              <p style="margin:0 0 6px;font-size:12px;color:#9ca3af;">
                © {{year}} FKstores — Golden Shopping Experience.
              </p>
              <p style="margin:0;font-size:12px;color:#d1d5db;">
                <a href="https://fkstores.com" style="color:#243e6b;text-decoration:none;">fkstores.com</a>
                &nbsp;·&nbsp;
                <a href="https://fkstores.com/blog" style="color:#243e6b;text-decoration:none;">Blog</a>
                &nbsp;·&nbsp;
                <a href="mailto:support@fkstores.com" style="color:#243e6b;text-decoration:none;">Support</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
